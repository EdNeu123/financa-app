rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isValidAmount(a) { return a is number && a >= 0.01 && a <= 9999999.99; }
    function isStr(v, max) { return v is string && v.size() >= 1 && v.size() <= max; }
    function isValidTxType(t) { return t in ['income', 'expense']; }
    function isValidCatType(t) { return t in ['income', 'expense', 'both']; }
    function isValidDate(d) { return d is string && d.size() == 10 && d.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$'); }
    function isValidColor(c) { return c is string && c.size() == 7 && c.matches('^#[0-9a-fA-F]{6}$'); }
    function isValidTags(t) { return t is list && t.size() <= 10; }

    match /transactions/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
        && isValidTxType(request.resource.data.type) && isStr(request.resource.data.description, 200)
        && isValidAmount(request.resource.data.amount) && isStr(request.resource.data.category, 80)
        && isValidDate(request.resource.data.date) && isValidTags(request.resource.data.tags);
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && isValidTxType(request.resource.data.type) && isStr(request.resource.data.description, 200)
        && isValidAmount(request.resource.data.amount) && isStr(request.resource.data.category, 80)
        && isValidDate(request.resource.data.date) && isValidTags(request.resource.data.tags);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /categories/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
        && isStr(request.resource.data.name, 80) && isValidCatType(request.resource.data.type) && isValidColor(request.resource.data.color);
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && isStr(request.resource.data.name, 80) && isValidCatType(request.resource.data.type) && isValidColor(request.resource.data.color);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /goals/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
        && isStr(request.resource.data.name, 80) && isValidAmount(request.resource.data.target) && isValidColor(request.resource.data.color)
        && (request.resource.data.deadline == null || isValidDate(request.resource.data.deadline));
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && isStr(request.resource.data.name, 80) && isValidAmount(request.resource.data.target) && isValidColor(request.resource.data.color);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /budgets/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
        && isStr(request.resource.data.category, 80) && isValidAmount(request.resource.data.limitAmount);
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /gamification/{userId} {
      allow read: if isAuth() && userId == request.auth.uid;
      allow write: if isAuth() && userId == request.auth.uid;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
